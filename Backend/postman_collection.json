{
  "info": {
    "name": "Interview AI Backend",
    "_postman_id": "3e88e77f-5d6c-4e9f-b2f7-7f0c11d9a501",
    "description": "API collection for interview-ai backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const setCookie = pm.response.headers.get('set-cookie');",
              "if (setCookie) {",
              "  const match = setCookie.match(/token=([^;]+)/);",
              "  if (match && match[1]) pm.environment.set('token', match[1]);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"sumit\",\n  \"email\": \"sumit@example.com\",\n  \"password\": \"Pass@1234\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      }
    },
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const setCookie = pm.response.headers.get('set-cookie');",
              "if (setCookie) {",
              "  const match = setCookie.match(/token=([^;]+)/);",
              "  if (match && match[1]) pm.environment.set('token', match[1]);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"sumit@example.com\",\n  \"password\": \"Pass@1234\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Auth - Get Me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Cookie", "value": "token={{token}}" }
        ],
        "url": "{{baseUrl}}/api/auth/get-me"
      }
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Cookie", "value": "token={{token}}" }
        ],
        "url": "{{baseUrl}}/api/auth/logout"
      }
    },
    {
      "name": "Interview - Generate Report",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let data = {};",
              "try { data = pm.response.json(); } catch (e) {}",
              "if (data && data.interviewReport && data.interviewReport._id) {",
              "  pm.environment.set('interviewId', data.interviewReport._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Cookie", "value": "token={{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "selfDescription", "value": "I am a full-stack developer with 2 years experience.", "type": "text" },
            { "key": "jobDescription", "value": "Looking for Node.js backend engineer with MongoDB and REST API experience.", "type": "text" },
            { "key": "resume", "type": "file", "src": "" }
          ]
        },
        "url": "{{baseUrl}}/api/interview/"
      }
    },
    {
      "name": "Interview - Get All Reports",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let data = {};",
              "try { data = pm.response.json(); } catch (e) {}",
              "if (data && Array.isArray(data.interviewReports) && data.interviewReports.length > 0) {",
              "  pm.environment.set('interviewId', data.interviewReports[0]._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Cookie", "value": "token={{token}}" }
        ],
        "url": "{{baseUrl}}/api/interview/"
      }
    },
    {
      "name": "Interview - Get Report By Id",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Cookie", "value": "token={{token}}" }
        ],
        "url": "{{baseUrl}}/api/interview/report/{{interviewId}}"
      }
    },
    {
      "name": "Interview - Generate Resume PDF",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Cookie", "value": "token={{token}}" }
        ],
        "url": "{{baseUrl}}/api/interview/resume/pdf/{{interviewId}}"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "interviewId", "value": "" }
  ]
}
